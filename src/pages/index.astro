---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 800px;
			}
			.intro {
				margin-bottom: 2em;
			}
			section {
				margin-bottom: 3em;
			}
			section h2 {
				border-bottom: 4px solid var(--accent);
				padding-bottom: 0.3em;
			}
			.trip-list {
				list-style: none;
				margin: 0;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 1em;
			}
			.trip-card {
				display: block;
				padding: 1em 1.2em;
				border-radius: 12px;
				background: white;
				box-shadow: var(--box-shadow);
				text-decoration: none;
				color: inherit;
				transition: 0.2s ease;
			}
			.trip-card:hover {
				transform: translateY(-2px);
			}
			.trip-card .title {
				margin: 0.1em 0 0.3em 0;
				color: rgb(var(--black));
			}
			.trip-card .description {
				margin: 0;
				color: rgb(var(--gray));
			}
			.info-section {
				padding: 1.5em;
				border-radius: 12px;
				background: rgb(var(--gray-light));
			}
			.info-section h2 {
				border-bottom: none;
				padding-bottom: 0;
			}
			.info-section ul {
				margin: 0.5em 0 0 0;
				padding-left: 1.2em;
			}
			.info-section li {
				margin-bottom: 0.4em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="intro">
				<h1>Petrillo Family Activities & Planning</h1>
				<p>
					This is our home base for keeping everyone in the loop on the outings we've planned and
					the trips we've already taken.
				</p>
			</div>

			<section>
				<h2>Trips</h2>
				<ul class="trip-list">
					<li>
						<a class="trip-card" href="/upcoming-trip/">
							<h3 class="title">Upcoming Trip Planner</h3>
							<p class="description">Countdown, itinerary, packing list, and budget for what's next.</p>
						</a>
					</li>
					<li>
						<a class="trip-card" href="/trips/japan-2026/">
							<h3 class="title">Japan 2026 Trip</h3>
							<p class="description">Photo retrospective from the trip.</p>
						</a>
					</li>
				</ul>
			</section>

			<section class="info-section">
				<h2>Info</h2>
				<p>A few things worth knowing:</p>
				<ul>
					<li>Have a new trip to add? Drop the details in the family group chat and it'll get added here.</li>
					<li>Questions or corrections? Reach out to whoever's organizing, or post in the group chat.</li>
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
